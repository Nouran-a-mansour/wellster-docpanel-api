# Database (used in config/database.yml)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=wellster
DB_PASSWORD=wellster

# Uncomment when using docker-compose (maps to port 5433 to avoid conflicts)
# DB_PORT=5433

# Production only — full DATABASE_URL overrides all DB_* vars
# DATABASE_URL=postgres://user:pass@host:5432/wellster_api_production

# CORS — comma-separated list of allowed origins (defaults to * in dev)
# CORS_ORIGINS=https://app.wellster.com
